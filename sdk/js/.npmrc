# npm auth for publishing — the token is read from the NPM_TOKEN environment
# variable, so it is NEVER stored in git. Do NOT paste a raw token here.
#
# Local publish:   export NPM_TOKEN=npm_xxxxxxxx   then  npm publish
# CI publish:      set a repository secret named NPM_TOKEN (see npm-publish.yml)
//registry.npmjs.org/:_authToken=${NPM_TOKEN}
